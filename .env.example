# OverfitGuard backend (Vercel serverless functions in /api).
# Set these in your Vercel project's Environment Variables (Settings → Environment Variables).
# WITHOUT them, local dev falls back to a non-persistent in-memory store — for tests/dev only.

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...             # SECRET: your Supabase "secret" key (or legacy service_role);
                                               # server-side only, bypasses RLS, never ship to the browser.
# No JWT secret needed: access tokens are verified against the project's public JWKS
# (${SUPABASE_URL}/auth/v1/.well-known/jwks.json), which is derived from SUPABASE_URL.

# --- Lemon Squeezy (Settings → Webhooks) ---
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR-WEBHOOK-SIGNING-SECRET
